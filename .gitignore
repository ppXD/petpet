# ── Rust build artefacts ───────────────────────────────────────────
/target
/desktop/src-tauri/target
**/*.rs.bk
Cargo.lock.bak

# ── Node / frontend build artefacts ────────────────────────────────
node_modules/
/desktop/dist
/desktop/dist-ssr
/desktop/.vite

# ── Tauri generated schemas ────────────────────────────────────────
/desktop/src-tauri/gen/schemas

# ── Local app state (never commit user data / databases) ───────────
*.db
*.db-journal
*.db-wal
*.db-shm
.petpet/

# ── Logs ───────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Editor / IDE ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS junk ────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db

# ── Per-user tool configs (not part of the project) ────────────────
.claude/

# ── Env / secrets (defensive — none currently in repo) ─────────────
.env
.env.*
!.env.example
*.pem
